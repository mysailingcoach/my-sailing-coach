diff --git a/backend/tests/test_maneuverClassification.js b/backend/tests/test_maneuverClassification.js
new file mode 100644
index 0000000..8da4ac1
--- /dev/null
+++ b/backend/tests/test_maneuverClassification.js
@@ -0,0 +1,132 @@
+import assert from 'node:assert/strict';
+import { computeAdvancedAnalysis } from '../utils/gpxParser.js';
+
+function buildTrackpoints({
+  headings = [],
+  windDirection = 0,
+  includeWind = true,
+  startTime = '2026-01-01T00:00:00.000Z',
+  stepSeconds = 1
+}) {
+  const t0 = new Date(startTime).getTime();
+  return headings.map((heading, idx) => ({
+    lat: 37 + idx * 0.0001,
+    lon: -122 + idx * 0.0001,
+    time: new Date(t0 + idx * stepSeconds * 1000).toISOString(),
+    heading,
+    sog: 8,
+    index: idx,
+    ...(includeWind
+      ? { wind: { direction: windDirection, speed: 12 } }
+      : {})
+  }));
+}
+
+function run() {
+  // Tack: cross head-to-wind (signed rel wind crosses 0).
+  const tackHeadings = [
+    40, 40, 40, 40, 40,
+    20, 5, 355, 340,
+    320, 320, 320, 320, 320
+  ];
+  const tackPoints = buildTrackpoints({
+    headings: tackHeadings,
+    windDirection: 0,
+    includeWind: true
+  });
+  const tackAnalysis = computeAdvancedAnalysis(tackPoints);
+  const tack = tackAnalysis.maneuvers[0];
+  assert.ok(tack, 'expected tack maneuver');
+  assert.equal(tack.type, 'Tack');
+
+  // Gybe: cross dead-downwind.
+  const gybeHeadings = [
+    170, 170, 170, 170, 170,
+    178, 182, 190, 200,
+    210, 210, 210, 210, 210
+  ];
+  const gybePoints = buildTrackpoints({
+    headings: gybeHeadings,
+    windDirection: 0,
+    includeWind: true
+  });
+  const gybeAnalysis = computeAdvancedAnalysis(gybePoints);
+  const gybe = gybeAnalysis.maneuvers[0];
+  assert.ok(gybe, 'expected gybe maneuver');
+  assert.equal(gybe.type, 'Gybe');
+
+  // Missing wind fallback should still detect maneuver by turn geometry.
+  const fallbackHeadings = [
+    40, 40, 40, 40, 40,
+    10, 350, 320,
+    320, 320, 320, 320, 320
+  ];
+  const fallbackPoints = buildTrackpoints({
+    headings: fallbackHeadings,
+    includeWind: false
+  });
+  const fallbackAnalysis = computeAdvancedAnalysis(fallbackPoints);
+  const fb = fallbackAnalysis.maneuvers[0];
+  assert.ok(fb, 'expected maneuver with missing wind');
+  assert.ok(fb.type === 'Tack' || fb.type === 'Gybe');
+
+  // Jitter scenario: no real maneuver, should not generate many false positives.
+  const jitter = [];
+  for (let i = 0; i < 120; i++) {
+    jitter.push(90 + (i % 2 === 0 ? 2 : -2));
+  }
+  const jitterPoints = buildTrackpoints({
+    headings: jitter,
+    windDirection: 0,
+    includeWind: true
+  });
+  const jitterAnalysis = computeAdvancedAnalysis(jitterPoints);
+  assert.ok(
+    jitterAnalysis.maneuvers.length <= 1,
+    `expected <=1 false maneuver in jitter case, got ${jitterAnalysis.maneuvers.length}`
+  );
+
+  console.log('✅ test_maneuverClassification passed');
+}
+
+run();
