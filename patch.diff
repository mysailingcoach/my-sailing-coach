+
+function inferDynamicWindow(trackpoints) {
+  const times = trackpoints
+    .map(p => p?.time ? new Date(p.time).getTime() : null)
+    .filter(t => Number.isFinite(t));
+
+  if (times.length < 3) {
+    return {
+      window: MANEUVER_WINDOW,
+      cooldown: MANEUVER_COOLDOWN_POINTS
+    };
+  }
+
+  const deltasSec = [];
+  for (let i = 1; i < times.length; i++) {
+    const d = (times[i] - times[i - 1]) / 1000;
+    if (Number.isFinite(d) && d > 0 && d < 120) {
+      deltasSec.push(d);
+    }
+  }
+
+  if (deltasSec.length === 0) {
+    return {
+      window: MANEUVER_WINDOW,
+      cooldown: MANEUVER_COOLDOWN_POINTS
+    };
+  }
+
+  const medianSec = quantile(deltasSec, 0.5);
+  const targetWindowSec = 6;
+  const targetCooldownSec = 14;
+
+  const window = Math.max(
+    3,
+    Math.min(
+      15,
+      Math.round(targetWindowSec / Math.max(0.2, medianSec))
+    )
+  );
+  const cooldown = Math.max(
+    MANEUVER_COOLDOWN_POINTS,
+    Math.round(targetCooldownSec / Math.max(0.2, medianSec))
+  );
+
+  return { window, cooldown };
+}
+
+function quantile(values, q) {
+  if (!Array.isArray(values) || values.length === 0) {
+    return 0;
+  }
+  const sorted = [...values].sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const base = Math.floor(pos);
+  const rest = pos - base;
+  if (sorted[base + 1] !== undefined) {
+    return sorted[base] + rest * (sorted[base + 1] - sorted[base]);
+  }
+  return sorted[base];
+}
+
+function smoothHeadings(trackpoints, windowSize = 5) {
+  if (!Array.isArray(trackpoints) || trackpoints.length === 0) {
+    return [];
+  }
+
+  const half = Math.floor(Math.max(3, windowSize) / 2);
+  const out = new Array(trackpoints.length).fill(null);
+
+  for (let i = 0; i < trackpoints.length; i++) {
+    const windowVals = [];
+    for (let j = i - half; j <= i + half; j++) {
+      const h = trackpoints[j]?.heading;
+      if (Number.isFinite(h)) {
+        windowVals.push(normalizeAngle(h));
+      }
+    }
+    out[i] = circularMeanDirection(windowVals);
+  }
+  return out;
+}
+
+function classifyManeuverWithWind(
+  beforePoint,
+  currentPoint,
+  afterPoint,
+  beforeHeading,
+  afterHeading
+) {
+  const windDirection =
+    beforePoint?.wind?.direction ??
+    currentPoint?.wind?.direction ??
+    afterPoint?.wind?.direction;
+
+  if (!Number.isFinite(windDirection)) {
+    return null;
+  }
+
+  const relBefore = signedRelativeWindAngle(beforeHeading, windDirection);
+  const relAfter = signedRelativeWindAngle(afterHeading, windDirection);
+
+  if (relBefore == null || relAfter == null) {
+    return null;
+  }
+
+  const crossedZero =
+    Math.sign(relBefore) !== Math.sign(relAfter) &&
+    Math.abs(relBefore) >= REL_WIND_TACK_CROSS_DEG &&
+    Math.abs(relAfter) >= REL_WIND_TACK_CROSS_DEG;
+
+  if (crossedZero) {
+    return 'Tack';
+  }
+
+  const crossedDdw = crossedDeadDownwind(relBefore, relAfter);
+  if (crossedDdw) {
+    return 'Gybe';
+  }
+
+  return null;
+}
+
+function signedRelativeWindAngle(heading, windDirection) {
+  if (!Number.isFinite(heading) || !Number.isFinite(windDirection)) {
+    return null;
+  }
+  let angle = normalizeAngle(heading - windDirection);
+  if (angle > 180) {
+    angle -= 360;
+  }
+  return angle;
+}
+
+function crossedDeadDownwind(a, b) {
+  const nearNeg180A = a <= -REL_WIND_GYBE_CROSS_DEG;
+  const nearPos180A = a >= REL_WIND_GYBE_CROSS_DEG;
+  const nearNeg180B = b <= -REL_WIND_GYBE_CROSS_DEG;
+  const nearPos180B = b >= REL_WIND_GYBE_CROSS_DEG;
+
+  return (
+    (nearNeg180A && nearPos180B) ||
+    (nearPos180A && nearNeg180B)
+  );
+}
 
